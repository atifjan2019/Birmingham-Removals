# Copy to .env.local for development and set the same values in your Vercel
# project settings for production. Values marked (SECURITY) currently have
# insecure in-code fallbacks — set real values and the fallbacks stop mattering.

# --- Admin / sessions (SECURITY: set these in production) ---
# 32+ byte random string used to sign the admin session JWT.
# Generate: openssl rand -base64 48
SESSION_SECRET=

# Admin dashboard + Worker API PIN used by the Next app to authenticate.
# Must match ADMIN_API_PIN configured on the Cloudflare Worker.
ADMIN_PIN=

# --- Worker API ---
# Base URL of the Cloudflare Worker (defaults to the production worker).
WORKER_API_URL=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Where new-booking notifications are sent.
BOOKING_NOTIFICATION_EMAIL=

# --- Google Maps / Places (postcode autocomplete) ---
# Browser-side key — restrict by HTTP referrer in Google Cloud console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- One-off admin creation script (scripts/create-admin.mjs) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
