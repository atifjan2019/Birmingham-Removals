{
  "name": "worker-api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "db:apply:local": "wrangler d1 execute DB --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute DB --remote --file=./schema.sql",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.84.0"
  }
}
